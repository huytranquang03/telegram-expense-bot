# Telegram Bot Token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# MongoDB Atlas Connection String
# Get this from MongoDB Atlas → Database → Connect → Connect your application
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/expense-bot?retryWrites=true&w=majority
